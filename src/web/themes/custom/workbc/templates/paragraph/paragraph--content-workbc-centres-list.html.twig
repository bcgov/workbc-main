{#
/**
 * @file
 * Default theme implementation to display a paragraph.
 *
 * Available variables:
 * - paragraph: Full paragraph entity.
 *   Only method names starting with "get", "has", or "is" and a few common
 *   methods such as "id", "label", and "bundle" are available. For example:
 *   - paragraph.getCreatedTime() will return the paragraph creation timestamp.
 *   - paragraph.id(): The paragraph ID.
 *   - paragraph.bundle(): The type of the paragraph, for example, "image" or "text".
 *   - paragraph.getOwnerId(): The user ID of the paragraph author.
 *   See Drupal\paragraphs\Entity\Paragraph for a full list of public properties
 *   and methods for the paragraph object.
 * - content: All paragraph items. Use {{ content }} to print them all,
 *   or print a subset such as {{ content.field_example }}. Use
 *   {{ content|without('field_example') }} to temporarily suppress the printing
 *   of a given child element.
 * - attributes: HTML attributes for the containing element.
 *   The attributes.class element may contain one or more of the following
 *   classes:
 *   - paragraphs: The current template type (also known as a "theming hook").
 *   - paragraphs--type-[type]: The current paragraphs type. For example, if the paragraph is an
 *     "Image" it would result in "paragraphs--type--image". Note that the machine
 *     name will often be in a short form of the human readable label.
 *   - paragraphs--view-mode--[view_mode]: The View Mode of the paragraph; for example, a
 *     preview would result in: "paragraphs--view-mode--preview", and
 *     default: "paragraphs--view-mode--default".
 * - view_mode: View mode; for example, "preview" or "full".
 * - logged_in: Flag for authenticated user status. Will be true when the
 *   current user is a logged-in member.
 * - is_admin: Flag for admin user status. Will be true when the current user
 *   is an administrator.
 *
 * @see template_preprocess_paragraph()
 *
 * @ingroup themeable
 */
#}

{%
  set classes = [
    'paragraph',
    paragraph.field_key[0].value ? 'paragraph--key--' ~ paragraph.field_key[0].value|clean_class,
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}

{% block paragraph %}
  <div{{ attributes.addClass(classes) }}>
    {% block content %}

      <div class="container-lg scroll-container">
        <ul class="nav nav-tabs no-hash" role="tablist">
          {% for key, region in regions %}
            <li class="nav-item" role="presentation">
              <a id="{{ key }}-tab" class="nav-link{{ loop.first ? ' active'}}" data-bs-toggle="tab" data-bs-target="#{{ key }}-content" aria-controls="{{key}}-content" aria-selected="{{ loop.first ? 'true':'false'}}" role="tab" href="#{{key}}">{{ region }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="tab-content" id="workbc-centres-list">
        {% for key, region in regions %}
          <div class="tab-pane{{ loop.first ? ' active'}}" id="{{ key }}-content" role="tabpanel" aria-labelledby="{{ key }}-tab">
            <div class="region-title">
              WorkBC Centres in {{ region }}
            </div>

            <div class="region-list">
              <div class="accordion accordion-flush workbc-centre-accordion" id="accordion-component-{{ key }}">
                {% for centre in centres[key] %}

                  <div class="accordion-header" id="header-{{ centre.id() }}">
                    <div class="accordion-header-link">
                      <a href="{{ centre.workbc_centre_url }}">{{ centre.label }}</a>
                    </div>
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{ centre.id() }}" aria-expanded="false" aria-controls="collapse-{{ centre.id() }}"></button>
                  </div>

                  <div id="collapse-{{ centre.id() }}" class="accordion-collapse collapse" aria-labelledby="header-{{ centre.id() }}" data-bs-parent="#accordion-component-{{ key }}">

                    <div class="centre-details-container">

                      <div class="centre-details centre-details-header">
                        <div class="centre-details-section">
                          <div class="centre-details-section-title">Address and Contact details</div>
                        </div>
                        <div class="centre-details-section centre-address">
                          <div class="centre-details-section-title">Hours of Operation</div>
                        </div>

                      </div>

                      <div class="centre-details centre-details-content">
                        <div class="centre-details-section centre-address">
                          <div>
                            <div>{{ centre.field_address.address_line1 }}</div>
                            {% if centre.field_address.address_line2 is not empty %}
                              <div>{{ centre.field_address.address_line2 }}</div>
                            {% endif %}
                            <div>{{ centre.field_address.locality }}, {{ centre.field_address.administrative_area }}, {{ centre.field_address.postal_code }}</div>
                            <div>{{ centre.field_phone.value }}</div>
                            <div class="centre-details-email">{{ centre.field_email.value }}</div>
                            <div><a target="_blank" rel="noopener noreferrer nofollow" href="{{ centre.field_website.uri }}">{{ centre.field_website.uri }}</a></div>
                          </div>
                        </div>

                        <div class="centre-details-section centre-hours">
                          <div>{{ centre.field_working_hours.value|raw }}</div>
                        </div>

                     </div>
                  </div>
                </div>
                  <div>
                    <hr>
                  </div>
                {% endfor %}
              </div>
            </div>

          </div>
        {% endfor %}
      </div>

    {% endblock %}
  </div>
{% endblock paragraph %}
